# Environment Variables for Local Development
# Place this file at: agrobridge/frontend/.env.local

# API URL - Points to your local backend
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Note: This file is for LOCAL development only
# For production (Vercel), set NEXT_PUBLIC_API_URL in Vercel dashboard:
NEXT_PUBLIC_API_URL=https://agrobridge-backend-pxm1.onrender.com

# Google Sign-In (OAuth 2.0 Client ID — same value as GOOGLE_CLIENT_ID on Render)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
